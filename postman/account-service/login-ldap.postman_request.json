{
  "info": {
    "name": "POST Login LDAP User",
    "description": "Login with LDAP/Active Directory credentials",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "ldap_username",
      "value": "your_ldap_username",
      "type": "string"
    },
    {
      "key": "ldap_password",
      "value": "your_ldap_password",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "POST /login-ldap",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    const response = pm.response.json();",
              "    pm.collectionVariables.set('access_token', response.access_token);",
              "    pm.collectionVariables.set('refresh_token', response.refresh_token);",
              "    console.log('LDAP login successful, tokens saved');",
              "} else {",
              "    console.log('LDAP login failed:', pm.response.code);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"username\": \"{{ldap_username}}\",\n    \"password\": \"{{ldap_password}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/login-ldap",
          "host": ["{{base_url}}"],
          "path": ["login-ldap"]
        },
        "description": "Login with LDAP/Active Directory credentials. User will be automatically imported to local database on first login."
      },
      "response": [
        {
          "name": "Success Response - 200 OK",
          "originalRequest": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"{{ldap_username}}\",\n    \"password\": \"{{ldap_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/login-ldap",
              "host": ["{{base_url}}"],
              "path": ["login-ldap"]
            }
          },
          "status": "OK",
          "code": 200,
          "_postman_previewlanguage": "json",
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "cookie": [],
          "body": "{\n    \"access_token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n    \"refresh_token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\"\n}"
        },
        {
          "name": "Error Response - 401 Unauthorized (Invalid LDAP Credentials)",
          "originalRequest": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"invalid_user\",\n    \"password\": \"wrong_password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/login-ldap",
              "host": ["{{base_url}}"],
              "path": ["login-ldap"]
            }
          },
          "status": "Unauthorized",
          "code": 401,
          "_postman_previewlanguage": "json",
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "cookie": [],
          "body": "{\n    \"error\": \"Authentication failed\"\n}"
        },
        {
          "name": "Error Response - 400 Bad Request (Invalid JSON)",
          "originalRequest": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"invalid\": \"json\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/login-ldap",
              "host": ["{{base_url}}"],
              "path": ["login-ldap"]
            }
          },
          "status": "Bad Request",
          "code": 400,
          "_postman_previewlanguage": "json",
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "cookie": [],
          "body": "{\n    \"error\": \"Invalid request format\"\n}"
        }
      ]
    }
  ]
}